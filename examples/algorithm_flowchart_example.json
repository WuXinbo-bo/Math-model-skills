[
  {
    "id": "start",
    "type": "start",
    "label": "开始",
    "edges": [
      {"to": "init"}
    ]
  },
  {
    "id": "init",
    "type": "process",
    "label": "初始化参数\n(种群大小N=50, 迭代T=100)",
    "edges": [
      {"to": "generate"}
    ]
  },
  {
    "id": "generate",
    "type": "process",
    "label": "生成初始种群",
    "edges": [
      {"to": "evaluate"}
    ]
  },
  {
    "id": "evaluate",
    "type": "process",
    "label": "计算适应度",
    "edges": [
      {"to": "check_converge"}
    ]
  },
  {
    "id": "check_converge",
    "type": "decision",
    "label": "是否达到\n收敛条件?",
    "edges": [
      {"to": "output", "condition": "是"},
      {"to": "select", "condition": "否"}
    ]
  },
  {
    "id": "select",
    "type": "process",
    "label": "选择操作\n(轮盘赌)",
    "edges": [
      {"to": "crossover"}
    ]
  },
  {
    "id": "crossover",
    "type": "process",
    "label": "交叉操作\n(概率Pc=0.8)",
    "edges": [
      {"to": "mutate"}
    ]
  },
  {
    "id": "mutate",
    "type": "process",
    "label": "变异操作\n(概率Pm=0.01)",
    "edges": [
      {"to": "evaluate"}
    ]
  },
  {
    "id": "output",
    "type": "process",
    "label": "输出最优解",
    "edges": [
      {"to": "end"}
    ]
  },
  {
    "id": "end",
    "type": "end",
    "label": "结束",
    "edges": []
  }
]
